APP_NAME="VKAAgroproducts"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vkaagro.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# SQLite. Absolute path on shared hosting, e.g. /home/USER/vka-app/database/database.sqlite
# Leave blank to use <app>/database/database.sqlite
DB_CONNECTION=sqlite
# DB_DATABASE=

# File drivers: SQLite locks under concurrent writes, and shared hosting has no Redis.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Seeded admin account (php artisan db:seed). Change ADMIN_PASSWORD before deploying.
ADMIN_USERNAME=admin
ADMIN_EMAIL=export@vkaagro.com
ADMIN_PASSWORD="vka@2026"

# Where new inquiry notifications are sent. Blank = don't send, just store in the DB.
INQUIRY_NOTIFY_EMAIL=

# Shared secret for the /__deploy post-deploy hook (migrations + cache warming).
# Generate a long random value and mirror it in the GitHub DEPLOY_TOKEN secret.
# Leave blank to disable the endpoint entirely (it will 404).
DEPLOY_TOKEN=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@vkaagro.com"
MAIL_FROM_NAME="${APP_NAME}"
